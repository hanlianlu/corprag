# dlightrag environment configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# RAG Mode (first decision — determines pipeline and model needs)
# ═══════════════════════════════════════════════════════════════════
# "caption" (default): document parsing → VLM captioning → text embedding → KG
#   - EMBEDDING_MODEL: text-only (e.g. text-embedding-3-large)
#   - VISION_MODEL: used for image captioning only (falls back to CHAT_MODEL)
#   - CHAT_MODEL: entity extraction + answer generation
#
# "unified": page rendering → multimodal embedding → VLM extraction → KG
#   - EMBEDDING_MODEL: must be multimodal (e.g. voyage-multimodal-3.5, Qwen3-VL-Embedding)
#   - VISION_MODEL: page description + rerank (if llm backend) + answer generation
#   - CHAT_MODEL: entity extraction only
DLIGHTRAG_RAG_MODE=caption
DLIGHTRAG_WORKING_DIR=./dlightrag_storage

# --- Caption mode only ---
DLIGHTRAG_PARSER=mineru

# --- Unified mode only ---
# DLIGHTRAG_PAGE_RENDER_DPI=250

# ═══════════════════════════════════════════════════════════════════
# Provider API Keys
# ═══════════════════════════════════════════════════════════════════
# Multiple providers can be active simultaneously (e.g. Anthropic for
# chat + OpenAI for embeddings). Each subsystem picks the key matching
# its provider setting.

# --- OpenAI (default provider)
DLIGHTRAG_OPENAI_API_KEY=
# DLIGHTRAG_OPENAI_BASE_URL=             # only needed for proxies or Ollama

# --- Azure OpenAI
# DLIGHTRAG_AZURE_OPENAI_API_KEY=
# DLIGHTRAG_AZURE_OPENAI_BASE_URL=        # e.g. https://your-resource.openai.azure.com/openai/v1

# --- Anthropic
# DLIGHTRAG_ANTHROPIC_API_KEY=

# --- Google Gemini
# DLIGHTRAG_GOOGLE_GEMINI_API_KEY=

# --- Qwen / DashScope (OpenAI-compatible)
# DLIGHTRAG_QWEN_API_KEY=
# DLIGHTRAG_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- MiniMax (OpenAI-compatible)
# DLIGHTRAG_MINIMAX_API_KEY=
# DLIGHTRAG_MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# --- Ollama (local; uses OpenAI-compatible endpoint)
# DLIGHTRAG_OPENAI_API_KEY=ollama
# DLIGHTRAG_OPENAI_BASE_URL=http://localhost:11434/v1
# DLIGHTRAG_LLM_PROVIDER=openai

# --- Xinference (local, OpenAI-compatible, no API key needed)
# DLIGHTRAG_XINFERENCE_BASE_URL=http://localhost:9997/v1

# --- OpenRouter (OpenAI-compatible)
# DLIGHTRAG_OPENROUTER_API_KEY=
# DLIGHTRAG_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Voyage (multimodal embedding for unified mode)
# DLIGHTRAG_VOYAGE_API_KEY=
# DLIGHTRAG_VOYAGE_BASE_URL=https://api.voyageai.com/v1

# ═══════════════════════════════════════════════════════════════════
# Models (configure based on RAG mode choice above)
# ═══════════════════════════════════════════════════════════════════
# Providers: openai, azure_openai, anthropic, google_gemini, qwen,
#            minimax, xinference, openrouter, voyage
# For Ollama: use provider=openai with OPENAI_BASE_URL pointing to Ollama.

# --- Chat / Vision ---
DLIGHTRAG_LLM_PROVIDER=openai
DLIGHTRAG_CHAT_MODEL=gpt-4.1-mini
# DLIGHTRAG_VISION_PROVIDER=             # defaults to llm_provider
DLIGHTRAG_VISION_MODEL=gpt-4.1-mini

# --- Extra Model Parameters (JSON, forwarded to provider API) ---
# DLIGHTRAG_CHAT_MODEL_KWARGS={"think": false}
# DLIGHTRAG_VISION_MODEL_KWARGS={"think": false}

# --- Embedding ---
# DLIGHTRAG_EMBEDDING_PROVIDER=          # defaults to llm_provider
DLIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large
DLIGHTRAG_EMBEDDING_DIM=1024

# ═══════════════════════════════════════════════════════════════════
# Reranking
# ═══════════════════════════════════════════════════════════════════
DLIGHTRAG_ENABLE_RERANK=true
DLIGHTRAG_RERANK_BACKEND=llm             # llm, cohere, jina, aliyun, azure_cohere
# DLIGHTRAG_RERANK_LLM_PROVIDER=         # defaults to llm_provider (only when backend=llm)
# DLIGHTRAG_RERANK_MODEL=                # defaults: cohere→rerank-v4.0-pro, jina→jina-reranker-v3, aliyun→qwen3-rerank
# DLIGHTRAG_RERANK_BASE_URL=             # point any backend at a compatible service (Xinference, LiteLLM, etc.)
# DLIGHTRAG_RERANK_API_KEY=              # not needed for local services

# ═══════════════════════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════════════════════
DLIGHTRAG_WORKSPACE=default

# --- Storage backends (default: all PostgreSQL) ---
# DLIGHTRAG_VECTOR_STORAGE=PGVectorStorage        # PGVectorStorage, MilvusVectorDBStorage, NanoVectorDBStorage, ChromaVectorDBStorage, FaissVectorDBStorage, QdrantVectorDBStorage
# DLIGHTRAG_GRAPH_STORAGE=PGGraphStorage           # PGGraphStorage, Neo4JStorage, NetworkXStorage, MemgraphStorage
# DLIGHTRAG_KV_STORAGE=PGKVStorage                 # PGKVStorage, JsonKVStorage, RedisKVStorage, MongoKVStorage
# DLIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage  # PGDocStatusStorage, JsonDocStatusStorage, RedisDocStatusStorage, MongoDocStatusStorage

# --- PostgreSQL (default backend) ---
DLIGHTRAG_POSTGRES_HOST=localhost
DLIGHTRAG_POSTGRES_PORT=5432
DLIGHTRAG_POSTGRES_USER=dlightrag
DLIGHTRAG_POSTGRES_PASSWORD=dlightrag
DLIGHTRAG_POSTGRES_DATABASE=dlightrag

# --- Neo4j (if graph_storage=Neo4JStorage) ---
# DLIGHTRAG_NEO4J_URI=bolt://localhost:7687
# DLIGHTRAG_NEO4J_USERNAME=neo4j_user
# DLIGHTRAG_NEO4J_PASSWORD=neo4j_password

# --- Milvus (if vector_storage=MilvusVectorDBStorage) ---
# DLIGHTRAG_MILVUS_URI=http://localhost:19530
# DLIGHTRAG_MILVUS_USER=
# DLIGHTRAG_MILVUS_PASSWORD=
# DLIGHTRAG_MILVUS_TOKEN=
# DLIGHTRAG_MILVUS_DB_NAME=default

# --- Qdrant (if vector_storage=QdrantVectorDBStorage) ---
# DLIGHTRAG_QDRANT_URL=http://localhost:6333
# DLIGHTRAG_QDRANT_API_KEY=

# --- pgvector HNSW tuning ---
DLIGHTRAG_PG_VECTOR_INDEX_TYPE=HNSW               # HNSW, IVFFLAT, VCHORDRQ
DLIGHTRAG_PG_HNSW_M=16                  # connections per node (index build)
DLIGHTRAG_PG_HNSW_EF_CONSTRUCTION=256   # candidate list size (index build)
DLIGHTRAG_PG_HNSW_EF_SEARCH=256         # candidate list size (query)

# --- Vector DB backend kwargs (JSON, forwarded to LightRAG) ---
# All backends: cosine_better_than_threshold (default: 0.3)
# Milvus index types: AUTOINDEX, HNSW, HNSW_SQ, HNSW_PQ, IVF_FLAT, IVF_SQ8, DISKANN, SCANN
# DLIGHTRAG_VECTOR_DB_KWARGS={"index_type": "HNSW", "metric_type": "COSINE", "hnsw_m": 32, "hnsw_ef_construction": 360, "hnsw_ef": 200}

# ═══════════════════════════════════════════════════════════════════
# Ingestion Performance
# ═══════════════════════════════════════════════════════════════════
# Defaults match LightRAG upstream. For local models (Ollama, Xinference)
# set all to 1 to avoid request queue buildup and timeouts.
# DLIGHTRAG_MAX_CONCURRENT_INGESTION=4  # files processed simultaneously
# DLIGHTRAG_MAX_PARALLEL_INSERT=2       # parallel document inserts
# DLIGHTRAG_MAX_ASYNC=4                 # concurrent LLM calls
# DLIGHTRAG_EMBEDDING_FUNC_MAX_ASYNC=8  # concurrent embedding calls
# DLIGHTRAG_EMBEDDING_BATCH_NUM=10      # texts per embedding batch
# DLIGHTRAG_EMBEDDING_REQUEST_TIMEOUT=120
# DLIGHTRAG_LLM_REQUEST_TIMEOUT=120

# ═══════════════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════════════
DLIGHTRAG_API_HOST=0.0.0.0
DLIGHTRAG_API_PORT=8100
# DLIGHTRAG_API_AUTH_TOKEN=

DLIGHTRAG_MCP_TRANSPORT=stdio            # stdio (local) or streamable-http (remote)
# DLIGHTRAG_MCP_HOST=0.0.0.0            # only with streamable-http
# DLIGHTRAG_MCP_PORT=8101               # only with streamable-http

# DLIGHTRAG_LOG_LEVEL=info
# DLIGHTRAG_REQUEST_TIMEOUT=600

# ═══════════════════════════════════════════════════════════════════
# Data Sources (optional)
# ═══════════════════════════════════════════════════════════════════
# DLIGHTRAG_BLOB_CONNECTION_STRING=
# DLIGHTRAG_SNOWFLAKE_ACCOUNT=
# DLIGHTRAG_SNOWFLAKE_USER=
# DLIGHTRAG_SNOWFLAKE_PASSWORD=
