# corprag environment configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# Provider API Keys (shared credential pool)
# ═══════════════════════════════════════════════════════════════════
# Multiple providers can be active simultaneously. For example,
# Anthropic for chat + OpenAI for embeddings. Configure all providers
# you need — each subsystem (chat, embedding, vision, rerank) picks
# the key matching its provider setting.

# --- OpenAI (default provider)
CORPRAG_OPENAI_API_KEY=

# --- Azure OpenAI
# CORPRAG_AZURE_OPENAI_API_KEY=
# CORPRAG_AZURE_OPENAI_BASE_URL=        # required; e.g. https://your-resource.openai.azure.com/openai/v1

# --- Anthropic
# CORPRAG_ANTHROPIC_API_KEY=

# --- Google Gemini
# CORPRAG_GOOGLE_GEMINI_API_KEY=

# --- Qwen / DashScope (OpenAI-compatible, CORPRAG_QWEN_BASE_URL defaults to dashscope.aliyuncs.com)
# CORPRAG_QWEN_API_KEY=

# --- MiniMax (OpenAI-compatible, CORPRAG_MINIMAX_BASE_URL defaults to api.minimax.chat)
# CORPRAG_MINIMAX_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Provider & Model Selection
# ═══════════════════════════════════════════════════════════════════
# Each subsystem selects a provider → uses that provider's key from above.

# --- Chat / Ingestion / Vision ---
# --- Supported: openai, azure_openai, anthropic, google_gemini, qwen, minimax
CORPRAG_LLM_PROVIDER=openai
CORPRAG_CHAT_MODEL=gpt-4.1-mini
CORPRAG_INGESTION_MODEL=gpt-4.1-mini
# CORPRAG_VISION_PROVIDER=             # defaults to llm_provider
CORPRAG_VISION_MODEL=gpt-4.1-mini

# --- Embedding ---
# CORPRAG_EMBEDDING_PROVIDER=          # defaults to llm_provider
CORPRAG_EMBEDDING_MODEL=text-embedding-3-large
CORPRAG_EMBEDDING_DIM=1024

# --- Reranking ---
CORPRAG_ENABLE_RERANK=true
CORPRAG_RERANK_BACKEND=llm             # "llm" (default), "cohere", or "azure_cohere"
# CORPRAG_RERANK_LLM_PROVIDER=         # defaults to llm_provider
# CORPRAG_RERANK_MODEL=                # defaults to ingestion_model
# --- Cohere reranking (not LLM-based) ---
# CORPRAG_COHERE_API_KEY=
# CORPRAG_COHERE_RERANK_MODEL=rerank-v4.0-pro
# --- Azure Cohere reranking ---
# CORPRAG_AZURE_COHERE_ENDPOINT=
# CORPRAG_AZURE_COHERE_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════════════════════

# --- PostgreSQL (default backend) ---
CORPRAG_POSTGRES_HOST=localhost
CORPRAG_POSTGRES_PORT=5432
CORPRAG_POSTGRES_USER=corprag
CORPRAG_POSTGRES_PASSWORD=corprag
CORPRAG_POSTGRES_DATABASE=corprag
CORPRAG_POSTGRES_WORKSPACE=default

# pgvector HNSW tuning (default backend based on pgvector)
CORPRAG_PG_VECTOR_INDEX_TYPE=HNSW
CORPRAG_PG_HNSW_M=32                  # connections per node (index build)
CORPRAG_PG_HNSW_EF_CONSTRUCTION=300   # candidate list size (index build)
CORPRAG_PG_HNSW_EF_SEARCH=300         # candidate list size (query, pgvector default: 40)

# --- Alternative backends (configure only if using non-default backend) ---
# Neo4j (graph_storage=Neo4JStorage)
# CORPRAG_NEO4J_URI=bolt://localhost:7687
# CORPRAG_NEO4J_USERNAME=neo4j_user
# CORPRAG_NEO4J_PASSWORD=neo4j_password
# Milvus (vector_storage=MilvusVectorDBStorage)
# CORPRAG_MILVUS_URI=http://localhost:19530

# ═══════════════════════════════════════════════════════════════════
# RAG Processing
# ═══════════════════════════════════════════════════════════════════
CORPRAG_WORKING_DIR=./corprag_storage
CORPRAG_PARSER=mineru
# CORPRAG_MINERU_BACKEND=              # auto-detect (default); options: pipeline, vlm-auto-engine, vlm-http-client, hybrid-auto-engine, hybrid-http-client

# ═══════════════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════════════
# --- REST API ---
CORPRAG_API_HOST=0.0.0.0
CORPRAG_API_PORT=8100
# CORPRAG_API_AUTH_TOKEN=

# --- MCP ---
CORPRAG_MCP_TRANSPORT=stdio            # "stdio" (local) or "streamable-http" (remote)
# CORPRAG_MCP_HOST=0.0.0.0            # only used with streamable-http
# CORPRAG_MCP_PORT=8100                # only used with streamable-http

# ═══════════════════════════════════════════════════════════════════
# Data Sources (optional)
# ═══════════════════════════════════════════════════════════════════
# CORPRAG_BLOB_CONNECTION_STRING=
# CORPRAG_SNOWFLAKE_ACCOUNT=
# CORPRAG_SNOWFLAKE_USER=
# CORPRAG_SNOWFLAKE_PASSWORD=
