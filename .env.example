# corprag environment configuration
# Copy to .env and fill in your values

# === PostgreSQL (Default Storage Backend) ===
CORPRAG_POSTGRES_HOST=localhost
CORPRAG_POSTGRES_PORT=5432
CORPRAG_POSTGRES_USER=rag
CORPRAG_POSTGRES_PASSWORD=rag
CORPRAG_POSTGRES_DATABASE=corprag
CORPRAG_POSTGRES_WORKSPACE=default

# === pgvector HNSW Index Configuration ===
CORPRAG_PG_VECTOR_INDEX_TYPE=HNSW
CORPRAG_PG_HNSW_M=32
CORPRAG_PG_HNSW_EF=300

# === Storage Backends (defaults to PostgreSQL, all LightRAG backends supported) ===
# CORPRAG_VECTOR_STORAGE=PGVectorStorage
# CORPRAG_GRAPH_STORAGE=PGGraphStorage
# CORPRAG_KV_STORAGE=PGKVStorage
# CORPRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# === LLM Provider ===
CORPRAG_LLM_PROVIDER=openai
# CORPRAG_LLM_PROVIDER=azure_openai

# OpenAI
CORPRAG_OPENAI_API_KEY=
# CORPRAG_OPENAI_BASE_URL=
CORPRAG_OPENAI_CHAT_MODEL=gpt-4.1-mini
CORPRAG_OPENAI_INGESTION_MODEL=gpt-4.1-mini
CORPRAG_OPENAI_VISION_MODEL=gpt-4.1-mini

# Azure OpenAI (if using azure_openai provider)
# CORPRAG_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
# CORPRAG_AZURE_OPENAI_API_KEY=
# CORPRAG_AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini

# === Embedding ===
CORPRAG_EMBEDDING_MODEL=text-embedding-3-large
CORPRAG_EMBEDDING_DIM=3072

# === Reranking ===
CORPRAG_ENABLE_RERANK=true
CORPRAG_RERANK_PROVIDER=llm
# CORPRAG_COHERE_API_KEY=

# === RAG Processing ===
CORPRAG_WORKING_DIR=./corprag_storage
CORPRAG_PARSER=mineru
# CORPRAG_MINERU_BACKEND=pipeline

# === Server ===
CORPRAG_API_HOST=0.0.0.0
CORPRAG_API_PORT=8100
CORPRAG_MCP_TRANSPORT=stdio
# CORPRAG_API_AUTH_TOKEN=

# === Optional: Azure Blob Storage ===
# CORPRAG_BLOB_CONNECTION_STRING=

# === Optional: Snowflake ===
# CORPRAG_SNOWFLAKE_ACCOUNT=
# CORPRAG_SNOWFLAKE_USER=
# CORPRAG_SNOWFLAKE_PASSWORD=

# === Optional: Neo4j (if graph_storage=Neo4JStorage) ===
# CORPRAG_NEO4J_URI=bolt://localhost:7687
# CORPRAG_NEO4J_USERNAME=neo4j
# CORPRAG_NEO4J_PASSWORD=

# === Optional: Milvus (if vector_storage=MilvusVectorDBStorage) ===
# CORPRAG_MILVUS_URI=http://localhost:19530
