# dlightrag environment configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# Provider API Keys (shared credential pool)
# ═══════════════════════════════════════════════════════════════════
# Multiple providers can be active simultaneously. For example,
# Anthropic for chat + OpenAI for embeddings. Configure all providers
# you need — each subsystem (chat, embedding, vision, rerank) picks
# the key matching its provider setting.

# --- OpenAI (default provider)
DLIGHTRAG_OPENAI_API_KEY=

# --- Azure OpenAI
# DLIGHTRAG_AZURE_OPENAI_API_KEY=
# DLIGHTRAG_AZURE_OPENAI_BASE_URL=        # required; e.g. https://your-resource.openai.azure.com/openai/v1

# --- Anthropic
# DLIGHTRAG_ANTHROPIC_API_KEY=

# --- Google Gemini
# DLIGHTRAG_GOOGLE_GEMINI_API_KEY=

# --- Qwen / DashScope (OpenAI-compatible, DLIGHTRAG_QWEN_BASE_URL defaults to dashscope-intl.aliyuncs.com)
# DLIGHTRAG_QWEN_API_KEY=
# DLIGHTRAG_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- MiniMax (OpenAI-compatible, DLIGHTRAG_MINIMAX_BASE_URL defaults to https://api.minimaxi.com/v1; use https://api.minimax.io/v1 for international)
# DLIGHTRAG_MINIMAX_API_KEY=
# DLIGHTRAG_MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# --- Ollama (local, OpenAI-compatible, no API key needed)
# DLIGHTRAG_OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Xinference (local, OpenAI-compatible, no API key needed)
# DLIGHTRAG_XINFERENCE_BASE_URL=http://localhost:9997/v1

# --- OpenRouter (OpenAI-compatible)
# DLIGHTRAG_OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Provider & Model Selection
# ═══════════════════════════════════════════════════════════════════
# Each subsystem selects a provider → uses that provider's key from above.

# --- Chat / Vision ---
# --- Supported: openai, azure_openai, anthropic, google_gemini, qwen, minimax, ollama, xinference, openrouter
DLIGHTRAG_LLM_PROVIDER=openai
DLIGHTRAG_CHAT_MODEL=gpt-4.1-mini
# DLIGHTRAG_VISION_PROVIDER=             # defaults to llm_provider
DLIGHTRAG_VISION_MODEL=gpt-4.1-mini

# --- Extra Model Parameters (JSON, forwarded to provider API) ---
# --- Useful for provider-specific options like disabling reasoning in Ollama qwen3 models.
# --- DLIGHTRAG_CHAT_MODEL_KWARGS={"think": false}
# --- DLIGHTRAG_VISION_MODEL_KWARGS={"think": false}

# --- Embedding ---
# DLIGHTRAG_EMBEDDING_PROVIDER=          # defaults to llm_provider
DLIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large
DLIGHTRAG_EMBEDDING_DIM=1024

# --- Reranking ---
DLIGHTRAG_ENABLE_RERANK=true
DLIGHTRAG_RERANK_BACKEND=llm             # ["llm", "cohere", "jina", "aliyun", or "azure_cohere"]
# --- LLM-based reranking (only when rerank_backend=llm) ---
# DLIGHTRAG_RERANK_LLM_PROVIDER=         # defaults to llm_provider

# DLIGHTRAG_RERANK_API_KEY=              # API key for rerank endpoint (not needed for local services)
# DLIGHTRAG_RERANK_MODEL=                # model name (defaults: cohere→rerank-v4.0-pro, jina→jina-reranker-v3, aliyun→qwen3-rerank)
# DLIGHTRAG_RERANK_BASE_URL=             # custom endpoint URL; point any backend at a compatible service

# ═══════════════════════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════════════════════
DLIGHTRAG_WORKSPACE=default

# --- Storage backends (default: all PostgreSQL) ---
# DLIGHTRAG_VECTOR_STORAGE=PGVectorStorage        # Options: PGVectorStorage, MilvusVectorDBStorage, NanoVectorDBStorage, ChromaVectorDBStorage, FaissVectorDBStorage, QdrantVectorDBStorage
# DLIGHTRAG_GRAPH_STORAGE=PGGraphStorage           # Options: PGGraphStorage, Neo4JStorage, NetworkXStorage, MemgraphStorage
# DLIGHTRAG_KV_STORAGE=PGKVStorage                 # Options: PGKVStorage, JsonKVStorage, RedisKVStorage, MongoKVStorage
# DLIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage  # Options: PGDocStatusStorage, JsonDocStatusStorage, RedisDocStatusStorage, MongoDocStatusStorage

# --- PostgreSQL (default backend) ---
DLIGHTRAG_POSTGRES_HOST=localhost
DLIGHTRAG_POSTGRES_PORT=5432
DLIGHTRAG_POSTGRES_USER=dlightrag
DLIGHTRAG_POSTGRES_PASSWORD=dlightrag
DLIGHTRAG_POSTGRES_DATABASE=dlightrag

# --- Neo4j (if graph_storage=Neo4JStorage) ---
# DLIGHTRAG_NEO4J_URI=bolt://localhost:7687
# DLIGHTRAG_NEO4J_USERNAME=neo4j_user
# DLIGHTRAG_NEO4J_PASSWORD=neo4j_password

# --- Milvus (if vector_storage=MilvusVectorDBStorage) ---
# DLIGHTRAG_MILVUS_URI=http://localhost:19530
# DLIGHTRAG_MILVUS_USER=
# DLIGHTRAG_MILVUS_PASSWORD=
# DLIGHTRAG_MILVUS_TOKEN=
# DLIGHTRAG_MILVUS_DB_NAME=default

# --- Qdrant (if vector_storage=QdrantVectorDBStorage) ---
# DLIGHTRAG_QDRANT_URL=http://localhost:6333
# DLIGHTRAG_QDRANT_API_KEY=

# --- pgvector HNSW tuning (configuration when default: PostgreSQL with pgvector) ---
DLIGHTRAG_PG_VECTOR_INDEX_TYPE=HNSW
DLIGHTRAG_PG_HNSW_M=16                  # connections per node (index build)
DLIGHTRAG_PG_HNSW_EF_CONSTRUCTION=256   # candidate list size (index build)
DLIGHTRAG_PG_HNSW_EF_SEARCH=256         # candidate list size (query, pgvector default: 40)

# --- VECTOR DB Backend Kwargs (in JSON format, forwarded to LightRAG vector_db_storage_cls_kwargs) ---
# --- Passthrough parameters for the selected vector storage backend.
# --- Each backend reads different keys; unused keys are **silently ignored.**
# --- **All backends share: cosine_better_than_threshold (default: 0.3)**
#
# --- Milvus index types: AUTOINDEX (default), HNSW, HNSW_SQ, HNSW_PQ, HNSW_PRQ, IVF_FLAT, IVF_SQ8, IVF_PQ, DISKANN, SCANN
# --- Milvus metric types: COSINE (default), L2, IP
#
# --- **Examples Below**:
#
# --- Milvus HNSW (classic):
# DLIGHTRAG_VECTOR_DB_KWARGS={"index_type": "HNSW", "metric_type": "COSINE", "hnsw_m": 32, "hnsw_ef_construction": 360, "hnsw_ef": 200}
#
# --- Milvus HNSW_SQ (memory-efficient, requires Milvus 2.6.8+):
# DLIGHTRAG_VECTOR_DB_KWARGS={"index_type": "HNSW_SQ", "sq_type": "SQ8", "hnsw_m": 32, "hnsw_ef_construction": 360， "hnsw_ef": 200}
#   sq_type options: SQ4U, SQ6, SQ8, BF16, FP16
#   sq_refine: false (default), sq_refine_type: FP32, sq_refine_k: 10
#
# --- Milvus IVF:
# DLIGHTRAG_VECTOR_DB_KWARGS={"index_type": "IVF_FLAT", "ivf_nlist": 1024, "ivf_nprobe": 16}
#
# --- Qdrant (currently only threshold; future params auto-supported if supported by dependency versions):
# DLIGHTRAG_VECTOR_DB_KWARGS={"cosine_better_than_threshold": 0.4}

# ═══════════════════════════════════════════════════════════════════
# RAG Processing
# ═══════════════════════════════════════════════════════════════════
DLIGHTRAG_WORKING_DIR=./dlightrag_storage
DLIGHTRAG_PARSER=mineru

# --- Ingestion Performance ---
# --- Defaults match LightRAG upstream. For local models (Ollama, Xinference, etc.)
# --- set all to 1 to avoid request queue buildup and timeouts.
# DLIGHTRAG_MAX_CONCURRENT_INGESTION=4  # files processed simultaneously (default: 4)
# DLIGHTRAG_MAX_PARALLEL_INSERT=2       # parallel document inserts (default: 2)
# DLIGHTRAG_MAX_ASYNC=4                 # concurrent LLM calls (default: 4)
# DLIGHTRAG_EMBEDDING_FUNC_MAX_ASYNC=8  # concurrent embedding calls (default: 8)
# DLIGHTRAG_EMBEDDING_BATCH_NUM=10      # texts per embedding batch (default: 10)
# DLIGHTRAG_LLM_REQUEST_TIMEOUT=120     # per-request timeout in seconds (default: 120)

# ═══════════════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════════════
# --- REST API ---
DLIGHTRAG_API_HOST=0.0.0.0
DLIGHTRAG_API_PORT=8100
# DLIGHTRAG_API_AUTH_TOKEN=

# --- MCP ---
DLIGHTRAG_MCP_TRANSPORT=stdio            # "stdio" (local) or "streamable-http" (remote)
# DLIGHTRAG_MCP_HOST=0.0.0.0            # only used with streamable-http
# DLIGHTRAG_MCP_PORT=8101                # only used with streamable-http

# ═══════════════════════════════════════════════════════════════════
# Data Sources (optional)
# ═══════════════════════════════════════════════════════════════════
# DLIGHTRAG_BLOB_CONNECTION_STRING=
# DLIGHTRAG_SNOWFLAKE_ACCOUNT=
# DLIGHTRAG_SNOWFLAKE_USER=
# DLIGHTRAG_SNOWFLAKE_PASSWORD=
